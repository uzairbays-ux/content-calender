# Copy this to .env and fill in your values

# From Railway: Postgres > Connect tab > copy "DATABASE_URL"
DATABASE_URL=postgresql://postgres:password@host.railway.internal:5432/railway

# Set to production on Railway
NODE_ENV=production

# Frontend: your Railway API service URL (set in Vite build)
VITE_API_URL=https://your-api.up.railway.app/api
